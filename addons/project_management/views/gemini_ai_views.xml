<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Gemini AI Provider Form View -->
    <record id="view_gemini_ai_provider_form" model="ir.ui.view">
        <field name="name">gemini.ai.provider.form</field>
        <field name="model">gemini.ai.provider</field>
        <field name="arch" type="xml">
            <form string="Google Gemini AI Configuration">
                <header>
                    <button name="action_test_connection" type="object" string="Test Connection" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="API Configuration">
                            <field name="api_key" password="True" placeholder="Nhập API key từ ai.google.dev"/>
                            <field name="model_name" widget="radio"/>
                            <field name="is_active"/>
                        </group>
                        
                        <group string="Advanced Settings">
                            <field name="temperature" widget="float"/>
                            <field name="max_tokens"/>
                        </group>
                    </group>
                    
                    <group string="Statistics">
                        <group>
                            <field name="total_requests" readonly="1"/>
                            <field name="last_used" readonly="1"/>
                        </group>
                    </group>
                    
                    <div class="alert alert-info" role="alert">
                        <h4>Hướng dẫn lấy API Key:</h4>
                        <ol>
                            <li>Truy cập: <a href="https://ai.google.dev/gemini-api/docs/api-key?hl=vi" target="_blank">https://ai.google.dev/gemini-api/docs/api-key</a></li>
                            <li>Đăng nhập Google Account</li>
                            <li>Click "Get an API key" → "Create API key"</li>
                            <li>Copy API key và paste vào trường trên</li>
                        </ol>
                        <p><strong>Lưu ý:</strong> API key miễn phí với giới hạn 60 requests/phút.</p>
                    </div>
                    
                    <div class="alert alert-warning" role="alert">
                        <h4>Các tính năng AI:</h4>
                        <ul>
                            <li>✅ Phân tích mô tả dự án tìm risks tiềm ẩn</li>
                            <li>✅ Generate mitigation plans thông minh</li>
                            <li>✅ Root cause analysis nâng cao (5 WHYs)</li>
                            <li>✅ Comprehensive project analysis</li>
                        </ul>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Gemini AI Provider Tree View -->
    <record id="view_gemini_ai_provider_tree" model="ir.ui.view">
        <field name="name">gemini.ai.provider.tree</field>
        <field name="model">gemini.ai.provider</field>
        <field name="arch" type="xml">
            <tree string="Gemini AI Providers">
                <field name="name"/>
                <field name="model_name"/>
                <field name="is_active"/>
                <field name="total_requests"/>
                <field name="last_used"/>
            </tree>
        </field>
    </record>
    
    <!-- Xóa action cũ (ir.actions.act_window) trước, vì Odoo không cho phép
         đổi model của 1 external ID đã tồn tại khi update module. -->
    <delete id="action_gemini_ai_provider" model="ir.actions.act_window"/>

    <!-- Action: dùng Server Action gọi action_open_settings() để luôn mở đúng
         bản ghi singleton có sẵn (tự tạo nếu chưa có), tránh mở form trống
         "New" mỗi lần vào menu (nguyên nhân gây lỗi "Only one Gemini provider
         can exist" khi bấm Save trên form trống đó). -->
    <record id="action_gemini_ai_provider" model="ir.actions.server">
        <field name="name">Gemini AI Settings</field>
        <field name="model_id" ref="model_gemini_ai_provider"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_settings()</field>
    </record>
    
    <!-- Menu đã được di chuyển sang menu.xml để tránh lỗi phụ thuộc thứ tự load -->
</odoo>